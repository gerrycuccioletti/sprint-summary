{
  "name": "sprint-summary",
  "version": "6.0.0",
  "description": "Sprint summary + Release health + Sprint analytics — Jira DC + Claude + Slack + Dashboard",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "start:slack": "node src/index.js --slack",
    "report": "node src/index.js --html --slack",
    "release": "node release-run.js",
    "release:report": "node release-run.js --slack --html",
    "release-set": "node release-set-run.js",
    "release-set:report": "node release-set-run.js --slack --html",
    "analytics": "node sprint-analytics-run.js",
    "analytics:report": "node sprint-analytics-run.js --slack --html",
    "schedule": "node src/scheduler.js",
    "test:now": "node run-now.js",
    "dashboard": "node src/dashboard/server.js",
    "slack-server": "node src/slack-command-server.js",
    "cr-kickback": "node cr-kickback-run.js",
    "qa-kickback": "node qa-kickback-run.js",
    "rfso-kickback": "node rfso-kickback-run.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@napi-rs/canvas": "^0.1.99",
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "express": "^4.22.1",
    "form-data": "^4.0.5",
    "node-cron": "^3.0.3"
  }
}