# ── Anthropic ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Jira Data Center ───────────────────────────────────────────────────────
JIRA_BASE_URL=https://your-jira-instance.company.com
JIRA_PAT=your_personal_access_token_here

# ── Sprint summary ─────────────────────────────────────────────────────────
# Comma-separated board IDs
JIRA_BOARD_IDS=1,2

# ── Per-version release health (optional) ──────────────────────────────────
# Runs one analysis per project+version pair
# Format: PROJECT:version1,version2;PROJECT2:version1
JIRA_RELEASE_VERSIONS=MYPROJECT:v2.1.0,v2.2.0
JIRA_PROJECT_KEY=MYPROJECT

# ── Release sets ───────────────────────────────────────────────────────────
# A release set groups fix versions into one cross-project analysis.
# Jira searches ALL accessible projects using the version clause you define.
#
# Step 1 — list your sets:
JIRA_RELEASE_SETS=Q2_2025,HOTFIX_MAY

# Step 2 — define each set using ONE of two modes:
#
#   LIST MODE — explicit comma-separated fix version names:
#     RELEASE_SET_{NAME}=version1,version2,version3
#     JQL generated: fixVersion in ("version1","version2","version3")
#
RELEASE_SET_HOTFIX_MAY=v2.0.1,hotfix-april
#
#   PATTERN MODE — Jira versionmatch() regex (evaluated server-side):
#     RELEASE_SET_{NAME}_PATTERN=<regex>
#     JQL generated: fixVersion in versionmatch("<regex>")
#
#   Supports full Java regex. Use (?i) for case-insensitive matching.
#   Use | to match multiple version names in one expression.
#
RELEASE_SET_Q2_2025_PATTERN=(?i)Guest App 1.76|MyCruise Web 1.86|Commerce SVCS Apr 26|SVCS Apr 26|MyCruise Hybris 1.59|Megaserv 1.76|Kiosk 2.2|Web Check-in 1.76.0|CJ Web 1.1|AEM 26.4.0|Branding Brand 1.76
#
#   Both modes find issues across ALL accessible Jira projects automatically.
#   In pattern mode, the matched version names are discovered from the results
#   and included in the report — you don't need to list them upfront.
#
# How to resolve the "team" dimension per issue:
#   project    → use Jira project key (always available, no config needed)
#   component  → use the first component assigned to the issue
#   label      → use a label that starts with RELEASE_TEAM_LABEL_PREFIX
#   customfield_XXXXX → use a Jira custom field ID (e.g. customfield_10200)
RELEASE_TEAM_FIELD=component
RELEASE_TEAM_LABEL_PREFIX=team-

# Issue types to include in release set analysis (default: Story,Bug)
RELEASE_SET_ISSUE_TYPES=Story,Bug

# Statuses to completely ignore — excluded from JQL and all counts
RELEASE_SET_IGNORE_STATUSES=Rejected,Closed

# ── Slack ──────────────────────────────────────────────────────────────────
# Default webhook — used when no specific webhook is found
SLACK_WEBHOOK_DEFAULT=https://hooks.slack.com/services/AAA/BBB/default
SEND_SLACK=true

# Per-board sprint webhooks:  SLACK_WEBHOOK_BOARD_{ID}
SLACK_WEBHOOK_BOARD_1=https://hooks.slack.com/services/AAA/BBB/board1

# Per-project release webhooks: SLACK_WEBHOOK_RELEASE_{PROJECT}
SLACK_WEBHOOK_RELEASE_MYPROJECT=https://hooks.slack.com/services/AAA/BBB/releases

# Per-set release set webhooks: SLACK_WEBHOOK_SET_{SETNAME}
SLACK_WEBHOOK_SET_Q2_2025=https://hooks.slack.com/services/AAA/BBB/q2-2025

# ── Scheduler ──────────────────────────────────────────────────────────────
CRON_SCHEDULE=0 9 * * 1          # Sprint: every Monday 9 AM
RELEASE_CRON_SCHEDULE=0 8 * * 2  # Per-version releases: every Tuesday 8 AM
SET_CRON_SCHEDULE=0 8 * * 1-5    # Release sets: weekdays 8 AM

TZ=America/New_York
RUN_NOW=false
SAVE_HTML_REPORT=false

# ── Dashboard ──────────────────────────────────────────────────────────────
DASHBOARD_PORT=3000

# ── Rule-based health & feasibility ───────────────────────────────────────
# Set to "true" to replace Claude's health/feasibility judgments with
# deterministic rules. When false (default), Claude decides.
RELEASE_SET_RULE_BASED=false

# Health thresholds (readiness %)
RULES_HEALTH_GREEN=80           # readiness >= this → Green
RULES_HEALTH_YELLOW=50          # readiness >= this → Yellow (else Red)

# Feasibility thresholds (overall readiness %)
RULES_FEASIBILITY_ON_TRACK=80   # readiness >= this → On track
RULES_FEASIBILITY_AT_RISK=50    # readiness >= this → At risk
RULES_FEASIBILITY_DELAYED=20    # readiness >= this → Likely delayed (else Should be descoped)

# Blocker count rules — override readiness regardless of %
RULES_BLOCKERS_FOR_RED=1        # cross-project blockers >= this → Red
RULES_BLOCKERS_FOR_YELLOW=1     # blockers per project/team >= this → Yellow

# notStarted % rules — override readiness if too much work unstarted
RULES_NOT_STARTED_RED_PCT=50    # notStarted% >= this → Red
RULES_NOT_STARTED_YELLOW_PCT=30 # notStarted% >= this → Yellow

# Show by-fix-version breakdown table in reports (default: false)
# When true, adds a "By version" tab to HTML, a section to Slack,
# and a table to the console and dashboard
RELEASE_SET_SHOW_BY_VERSION=false

# ── Sprint analytics (GreenHopper) ─────────────────────────────────────────
# Board IDs to analyze — defaults to JIRA_BOARD_IDS if not set
SPRINT_ANALYTICS_BOARD_IDS=1,2

# How many past sprints to include in velocity chart (default: 6)
SPRINT_ANALYTICS_VELOCITY_SPRINTS=6

# Skip Claude API call — stats are computed locally, health is rule-based
SPRINT_ANALYTICS_DRY_RUN=false
